node_modules

# GitHub Pages artifact staging directory (created by the CI workflow, but
# may also appear locally if someone simulates the CI steps). Never commit.
_site/

# Build output — generated by `npm run build` from src/index.template.html + data/.
# CI rebuilds this on every deploy; keeping it out of git avoids duplicate diffs.
index.html

# Legacy / accidental build output directory (not used by this project).
dist/
